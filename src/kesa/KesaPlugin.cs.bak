                {
                    objtarget.GetComponent<Renderer>().materials= recupmats;
                }
                */
            }
            recupmats = catchmat("engine_1v_methalox_cornet", "vfx_exh_mesh_main_01", "skinnedmat");
            objtarget = GetChildGameObject(prefab, "kesavfx1");
            if (objtarget != null)
            {
